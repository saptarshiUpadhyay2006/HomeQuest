<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'HomeQuest - Discover Your Perfect Stay' %></title>
    <meta name="description" content="<%= typeof description !== 'undefined' ? description : 'Discover the most beautiful and unique stays around the world with HomeQuest. Book your perfect getaway today.' %>">
    
    <!-- SEO Keywords -->
    <meta name="keywords" content="vacation rentals, holiday homes, HomeQuest, travel, luxury stays, unique stays, booking">
    <meta name="author" content="HomeQuest Team">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://homequest-spuk.vercel.app/">
    <meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'HomeQuest - Discover Your Perfect Stay' %>">
    <meta property="og:description" content="<%= typeof description !== 'undefined' ? description : 'Discover the most beautiful and unique stays around the world with HomeQuest. Book your perfect getaway today.' %>">
    <meta property="og:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : '/logo.png' %>">

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image">
    <meta property="twitter:url" content="https://homequest-spuk.vercel.app/">
    <meta property="twitter:title" content="<%= typeof title !== 'undefined' ? title : 'HomeQuest - Discover Your Perfect Stay' %>">
    <meta property="twitter:description" content="<%= typeof description !== 'undefined' ? description : 'Discover the most beautiful and unique stays around the world with HomeQuest. Book your perfect getaway today.' %>">
    <meta property="twitter:image" content="<%= typeof ogImage !== 'undefined' ? ogImage : '/logo.png' %>">

    <!-- Canonical URL -->
    <link rel="canonical" href="https://homequest-spuk.vercel.app<%= typeof canonicalUrl !== 'undefined' ? canonicalUrl : '' %>">

    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css" 
    rel="stylesheet" 
    integrity="sha384-LN+7fdVzj6u52u30Kp6M/trliBMCMKTyK833zpbD+pXdCLuTusPj697FH4R/5mcr" 
    crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.0/css/all.min.css" integrity="sha512-DxV+EoADOkOygM4IR9yXP8Sb2qwgidEmeqAEmDKIOfPRQZOWbXCzLC6vjbZyy0vPisbH2SyW27+ddLVCN+OMzQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Outfit:wght@100..900&display=swap" rel="stylesheet">
    <link href="/css/rating.css" rel="stylesheet">
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.14.0/mapbox-gl.css" rel="stylesheet">
    <script src="https://api.mapbox.com/mapbox-gl-js/v3.14.0/mapbox-gl.js"></script>
    <meta name="google-site-verification" content="q5n2v2K85zpUJ7apJTjLRznJanr2BMcB1hlZNKShjlw" />
    <script>
        // Apply theme immediately to prevent flash
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
</head>
<body>
    <div style="
    background:#ffe6e6;
    color:#900;
    padding:8px;
    font-weight:bold;
    font-size: small;
    text-align:center;
    border-bottom:1px solid #f5c2c2;
  ">
    Disclaimer: This website is a college major project created for educational purposes only.
    It is not a commercial service and does not perform real transactions.
  </div>
    <%- include("../includes/navbar.ejs")%>
    <div class="container">
        <%- include("../includes/flash.ejs")%><%-body%>
    </div>
    <%- include("../includes/footer.ejs")%>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/js/bootstrap.bundle.min.js" 
    integrity="sha384-ndDqU0Gzau9qJ1lfW4pNLlhNTkCfHzAVBReH9diLvGRem5+R9g2FzA8ZGN954O5Q" 
    crossorigin="anonymous">
    </script>
    <script src="/js/script.js"></script>
</body> 

</html>
