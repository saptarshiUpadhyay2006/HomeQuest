<% layout("/layouts/boilerplate") -%>
    <script>
        const mapToken = "<%=process.env.MAP_TOKEN%>";
    </script>
    <script id="listing-data" type="application/json">
    <%- JSON.stringify(listing) %>
</script>
    <script>
        const listing = JSON.parse(document.getElementById('listing-data').textContent);
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <style>
        .hero-img-container {
            width: 100%;
            height: 65vh;
            border-radius: 2rem;
            overflow: hidden;
            margin-bottom: 3rem;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.2);
            position: relative;
            background: linear-gradient(135deg, rgba(227, 73, 73, 0.1) 0%, rgba(227, 73, 73, 0.05) 100%);
        }

        .swiper {
            width: 100%;
            height: 100%;
        }

        .swiper-slide img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .swiper-slide:hover img {
            transform: scale(1.05);
        }

        .swiper-button-next,
        .swiper-button-prev {
            color: white !important;
            background: rgba(227, 73, 73, 0.6);
            width: 45px !important;
            height: 45px !important;
            border-radius: 50%;
            backdrop-filter: blur(8px);
            transition: all 0.3s ease;
        }

        .swiper-button-next:hover,
        .swiper-button-prev:hover {
            background: rgba(227, 73, 73, 0.9);
            transform: scale(1.1);
        }

        .swiper-button-next:after,
        .swiper-button-prev:after {
            font-size: 1.1rem !important;
            font-weight: 900;
        }

        .swiper-pagination-bullet-active {
            background: #e34949 !important;
            width: 25px;
            border-radius: 5px;
        }

        @media (max-width: 768px) {
            .hero-img-container {
                height: 45vh;
                border-radius: 1.5rem;
                margin-bottom: 2rem;
            }
        }

        .host-info {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            margin-bottom: 2.5rem;
            padding: 1rem;
            background: linear-gradient(to right, rgba(227, 73, 73, 0.05), transparent);
            border-radius: 1rem;
        }

        .host-avatar {
            width: 65px;
            height: 65px;
            border-radius: 20px;
            background: linear-gradient(135deg, #e34949 0%, #ff6b6b 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            font-weight: 800;
            box-shadow: 0 8px 20px rgba(227, 73, 73, 0.4);
            transform: rotate(-3deg);
            transition: all 0.3s ease;
        }

        .host-info:hover .host-avatar {
            transform: rotate(0deg) scale(1.05);
        }

        .sticky-box {
            position: sticky;
            top: 110px;
            background: var(--card-bg);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 2px solid var(--border-color);
            border-radius: 2rem;
            padding: 2.5rem;
            box-shadow: 0 20px 45px rgba(0, 0, 0, 0.12);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            overflow: hidden;
        }

        .sticky-box::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 6px;
            background: linear-gradient(90deg, #e34949, #ff6b6b);
        }

        @media (max-width: 991px) {
            .sticky-box {
                position: static;
                margin-top: 2.5rem;
                margin-bottom: 4rem;
                padding: 1.5rem;
            }
        }

        .sticky-box:hover {
            transform: translateY(-8px);
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.18);
            border-color: rgba(227, 73, 73, 0.3);
        }

        .price-display {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 0;
            color: #e34949;
            line-height: 1;
        }

        .pricing-card-wrapper {
            background: rgba(227, 73, 73, 0.05);
            padding: 1.2rem;
            border-radius: 1.2rem;
            border: 1px solid rgba(227, 73, 73, 0.1);
        }

        .pricing-badge-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            flex-wrap: wrap;
        }

        .pricing-item {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 0.2rem;
        }

        .pricing-divider {
            width: 1px;
            height: 40px;
            background: rgba(0, 0, 0, 0.1);
        }

        [data-theme="dark"] .pricing-divider {
            background: rgba(255, 255, 255, 0.1);
        }

        .price-type {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 700;
            color: var(--text-muted);
        }

        .review-card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 1.5rem;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
            transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            position: relative;
            overflow: hidden;
        }

        .review-card::after {
            content: '"';
            position: absolute;
            top: 10px;
            right: 20px;
            font-size: 4rem;
            color: rgba(227, 73, 73, 0.1);
            font-family: serif;
        }

        .review-card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 15px 35px rgba(227, 73, 73, 0.15);
            border-color: rgba(227, 73, 73, 0.2);
        }

        #map {
            height: 450px;
            width: 100%;
            border-radius: 1.5rem;
            margin-top: 2rem;
            overflow: hidden;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);
            border: 4px solid var(--card-bg);
            transition: height 0.3s ease;
            background-color: #eee; /* Fallback visibility */
        }

        @media (max-width: 768px) {
            #map {
                height: 350px;
            }
        }

        @media (max-width: 576px) {
            #map {
                height: 300px !important;
                margin-top: 1.5rem;
            }
        }

        .category-badge {
            background: linear-gradient(135deg, #e34949 0%, #ff6b6b 100%);
            padding: 0.6rem 1.4rem;
            border-radius: 2rem;
            font-size: 0.9rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 0.6rem;
            color: white !important;
            box-shadow: 0 4px 15px rgba(227, 73, 73, 0.3);
            text-transform: uppercase;
            letter-spacing: 1px;
            border: none;
            transition: all 0.3s ease;
        }

        .category-badge:hover {
            transform: translateY(-3px) rotate(2deg);
            box-shadow: 0 8px 20px rgba(227, 73, 73, 0.5);
        }

        h1 {
            font-size: clamp(2.2rem, 5vw, 3.2rem);
            font-weight: 900;
            letter-spacing: -1px;
            color: var(--text-color);
            margin-bottom: 0.8rem;
            line-height: 1.1;
        }

        @media (max-width: 576px) {
            h1 {
                font-size: 1.8rem;
                margin-bottom: 0.5rem;
            }
            
            .section-title {
                font-size: 1.5rem;
            }
        }

        .section-title {
            font-size: 1.8rem;
            font-weight: 800;
            margin-bottom: 1.5rem;
            position: relative;
            display: inline-block;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 0;
            width: 40px;
            height: 4px;
            background: #e34949;
            border-radius: 2px;
        }

        .btn-primary-custom {
            background: linear-gradient(135deg, #e34949 0%, #ff4b4b 100%);
            border: none;
            color: white;
            border-radius: 1rem;
            padding: 1.2rem 1.5rem;
            font-weight: 800;
            font-size: 1.1rem;
            width: 100%;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            box-shadow: 0 8px 25px rgba(227, 73, 73, 0.4);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-primary-custom:hover {
            transform: translateY(-4px) scale(1.02);
            box-shadow: 0 12px 30px rgba(227, 73, 73, 0.6);
            color: white;
        }

        .btn-outline-custom {
            color: var(--text-color);
            background: transparent;
            border: 2px solid #e34949;
            border-radius: 1rem;
            padding: 1rem 1.5rem;
            font-weight: 800;
            font-size: 1.1rem;
            width: 100%;
            transition: all 0.3s ease;
        }

        .btn-outline-custom:hover {
            background: #e34949;
            color: white;
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(227, 73, 73, 0.3);
        }

        .wishlist-btn-show {
            position: absolute;
            top: 2.5rem;
            right: 2.5rem;
            z-index: 10;
            background: var(--card-bg);
            border: none;
            width: 60px;
            height: 60px;
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            color: var(--text-color);
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .wishlist-btn-show:hover {
            transform: scale(1.1) rotate(5deg);
            background: #e34949;
            color: white !important;
        }

        .wishlist-btn-show:hover .fa-heart {
            color: white !important;
        }

        .wishlist-btn-show .fa-solid {
            color: #e34949;
        }

        .amenity-item {
            display: flex;
            align-items: center;
            gap: 1.2rem;
            margin-bottom: 1.5rem;
            font-size: 1.1rem;
            padding: 1rem;
            border-radius: 1rem;
            background: rgba(227, 73, 73, 0.03);
            transition: all 0.3s ease;
            border: 1px solid transparent;
        }

        .amenity-item:hover {
            background: rgba(227, 73, 73, 0.08);
            transform: translateX(10px);
            border-color: rgba(227, 73, 73, 0.2);
        }

        .amenity-item i {
            font-size: 1.5rem;
            color: #e34949;
            width: 35px;
            height: 35px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(227, 73, 73, 0.2);
        }

        [data-theme="dark"] .amenity-item i {
            background: #222;
        }

        .review-author-avatar {
            width: 45px;
            height: 45px;
            border-radius: 12px;
            background: linear-gradient(135deg, #333 0%, #111 100%);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
        }

        [data-theme="dark"] .review-author-avatar {
            background: linear-gradient(135deg, #e34949 0%, #ff6b6b 100%);
        }
    </style>

    <div class="container mt-4 mb-5">
        <!-- Header Section -->
        <div class="mb-4">
            <h1>
                <%= listing.title %>
            </h1>
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mt-2">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    <span class="text-muted"><i class="fa-solid fa-location-dot me-1"></i>
                        <%= listing.location %>, <%= listing.country %>
                    </span>
                    <% if(listing.category) { %>
                        <span class="category-badge"><i class="fa-solid fa-tag"></i>
                            <%= listing.category %>
                        </span>
                        <% } %>
                </div>
                <% if(listing.reviews && listing.reviews.length> 0) { %>
                    <div class="text-muted d-flex align-items-center gap-1">
                        <i class="fa-solid fa-star text-warning"></i>
                        <b>
                            <%= (listing.reviews.reduce((acc, r)=> acc + r.rating, 0) /
                                listing.reviews.length).toFixed(1) %>
                        </b>
                        <span class="text-decoration-underline">(<%= listing.reviews.length %> reviews)</span>
                    </div>
                    <% } %>
            </div>
        </div>

        <!-- Hero Image Gallery (Swiper) -->
        <div class="hero-img-container">
            <div class="swiper mySwiper">
                <div class="swiper-wrapper">
                    <% if(listing.images && listing.images.length> 0) { %>
                        <% for(let img of listing.images) { %>
                            <div class="swiper-slide">
                                <img src="<%= img.url %>" alt="<%= listing.title %>">
                            </div>
                            <% } %>
                                <% } else if(listing.image && listing.image.url) { %>
                                    <div class="swiper-slide">
                                        <img src="<%= listing.image.url %>" alt="<%= listing.title %>">
                                    </div>
                                    <% } %>
                </div>
                <div class="swiper-button-next"></div>
                <div class="swiper-button-prev"></div>
                <div class="swiper-pagination"></div>
            </div>

            <% if(currUser) { %>
                <button class="wishlist-btn-show" onclick="toggleWishlist(event, '<%= listing._id %>')">
                    <i
                        class="<%= currUser.wishlist && currUser.wishlist.includes(listing._id) ? 'fa-solid' : 'fa-regular' %> fa-heart"></i>
                </button>
                <% } %>
        </div>

        <div class="row">
            <!-- Left Column: Details & Reviews -->
            <div class="col-lg-8 pe-lg-5">
                <!-- Host Info -->
                <div class="host-info">
                    <div class="host-avatar">
                        <%= listing.owner ? listing.owner.username.charAt(0).toUpperCase() : "?" %>
                    </div>
                    <div>
                        <h5 class="mb-0">Hosted by <%= listing.owner ? listing.owner.username : "Unknown Host" %>
                        </h5>
                        <small class="text-muted">Superhost</small>
                    </div>
                </div>

                <hr class="my-4 text-muted">

                <!-- Description -->
                <div class="mb-5">
                    <h4 class="section-title">About this space</h4>
                    <p class="text-muted" style="line-height: 1.8;">
                        <%= listing.description %>
                    </p>
                </div>

                <hr class="my-4 text-muted">

                <!-- Amenities -->
                <% if(listing.amenities && listing.amenities.length> 0) { %>
                    <div class="mb-5">
                        <h4 class="section-title">What this place offers</h4>
                        <div class="row mt-3">
                            <% const amenityIcons={ "Wifi" : "fa-wifi" , "Pool" : "fa-person-swimming" , "AC"
                                : "fa-wind" , "Kitchen" : "fa-kitchen-set" , "Parking" : "fa-square-p" , "Gym"
                                : "fa-dumbbell" , "TV" : "fa-tv" , "Workspace" : "fa-laptop-code" }; %>
                                <% for(let amenity of listing.amenities) { %>
                                    <div class="col-12 col-md-6 amenity-item">
                                        <i class="fa-solid <%= amenityIcons[amenity] || 'fa-check' %>"></i>
                                        <span>
                                            <%= amenity %>
                                        </span>
                                    </div>
                                    <% } %>
                        </div>
                    </div>
                    <hr class="my-4 text-muted">
                    <% } %>

                        <!-- Map -->
                        <div class="mb-5">
                            <h4 class="section-title">Where you'll be</h4>
                            <p class="text-muted mb-3">
                                <%= listing.location %>, <%= listing.country %>
                            </p>
                            <div id="map" class="map-container"></div>
                        </div>

                        <hr class="my-4 text-muted">

                        <!-- Weather & Nearby Sections -->
                <div class="row mt-4 g-4">
                    <!-- Weather Card -->
                    <div class="col-md-6">
                        <div class="card h-100 border-0 shadow-sm p-4" style="border-radius: 1.5rem; background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%); color: white;">
                            <h5 class="fw-800 mb-3"><i class="fa-solid fa-cloud-sun me-2"></i>Current Weather</h5>
                            <div id="weather-content" class="text-center py-2">
                                <div class="spinner-border text-light" role="status">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Nearby Attractions -->
                    <div class="col-md-6">
                        <div class="card h-100 border-0 shadow-sm p-4" style="border-radius: 1.5rem; background: var(--card-bg); border: 1px solid var(--border-color) !important;">
                            <h5 class="fw-800 mb-3" style="color: #e34949;"><i class="fa-solid fa-utensils me-2"></i>Nearby Hotspots</h5>
                            <div id="nearby-list" class="d-flex flex-column gap-2">
                                <div class="text-center py-3">
                                    <div class="spinner-border text-danger" role="status">
                                        <span class="visually-hidden">Searching...</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-5 text-muted">
                
                <!-- Review Section -->
                        <div class="mb-4">
                            <h4 class="mb-4">
                                <i class="fa-solid fa-star text-warning me-2"></i>
                                <% if(listing.reviews && listing.reviews.length> 0) { %>
                                    <%= (listing.reviews.reduce((acc, r)=> acc + r.rating, 0) /
                                        listing.reviews.length).toFixed(1) %> · <%= listing.reviews.length %> reviews
                                            <% } else { %>
                                                No reviews yet
                                                <% } %>
                            </h4>

                            <% if(currUser) { %>
                                <div class="card review-card mb-4 p-4">
                                    <h5 class="mb-3">Leave a Review</h5>
                                    <form action="/listings/<%= listing._id%>/reviews" method="POST" novalidate
                                        class="needs-validation">
                                        <div class="mb-3">
                                            <label class="form-label text-muted">Overall rating</label>
                                            <fieldset class="starability-slot">
                                                <input type="radio" id="no-rate" class="input-no-rate"
                                                    name="review[rating]" value="1" checked aria-label="No rating." />
                                                <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                                <label for="first-rate1" title="Terrible">1 star</label>
                                                <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                                <label for="first-rate2" title="Not good">2 stars</label>
                                                <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                                <label for="first-rate3" title="Average">3 stars</label>
                                                <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                                <label for="first-rate4" title="Very good">4 stars</label>
                                                <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                                <label for="first-rate5" title="Amazing">5 stars</label>
                                            </fieldset>
                                        </div>
                                        <div class="mb-4">
                                            <label for="comment" class="form-label text-muted">Share your
                                                experience</label>
                                            <textarea name="review[comment]" id="comment" cols="30" rows="4"
                                                class="form-control" required
                                                placeholder="What was it like?"></textarea>
                                            <div class="invalid-feedback">Please add some comment for review</div>
                                        </div>
                                        <button class="btn btn-primary-custom" style="width: auto;">Submit
                                            Review</button>
                                    </form>
                                </div>
                                <% } %>

                                    <div class="row row-cols-1 row-cols-md-2 g-4 mt-2">
                                        <% for(review of listing.reviews) { %>
                                            <div class="col">
                                                <div class="card review-card h-100 p-3 border-0">
                                                    <div class="d-flex align-items-center mb-3">
                                                        <div class="review-author-avatar me-3">
                                                            <%= review.author.username.charAt(0).toUpperCase() %>
                                                        </div>
                                                        <div>
                                                            <h6 class="mb-0">
                                                                <%= review.author.username %>
                                                            </h6>
                                                        </div>
                                                    </div>
                                                    <div class="mb-2">
                                                        <p class="starability-result m-0"
                                                            data-rating="<%= review.rating%>">
                                                            Rated: <%= review.rating%> stars
                                                        </p>
                                                    </div>
                                                    <p class="card-text text-muted" style="font-size: 0.95rem;">
                                                        <%= review.comment %>
                                                    </p>

                                                    <% if(currUser && review.author._id.equals(currUser.id)) { %>
                                                        <form method="POST"
                                                            action="/listings/<%= listing._id%>/reviews/<%= review._id%>?_method=DELETE"
                                                            class="mt-auto pt-3">
                                                            <button
                                                                class="btn btn-sm btn-outline-danger">Delete</button>
                                                        </form>
                                                        <% } %>
                                                </div>
                                            </div>
                                            <% } %>
                                    </div>
                        </div>
            </div>

            <!-- Right Column: Sticky Box -->
            <div class="col-lg-4 mt-4 mt-lg-0">
                <div class="sticky-box">
                    <div class="pricing-card-wrapper mb-4">
                        <div class="pricing-badge-row">
                            <div class="pricing-item">
                                <span class="price-type">Weekday</span>
                                <span class="price-display">&#8377;<%= listing.price.toLocaleString("en-IN") %></span>
                            </div>
                            <div class="pricing-divider"></div>
                            <div class="pricing-item text-end">
                                <span class="price-type">Weekend</span>
                                <span class="price-display" style="color: #00a699;">&#8377;<%= listing.weekendPrice ? listing.weekendPrice.toLocaleString("en-IN") : listing.price.toLocaleString("en-IN") %></span>
                            </div>
                        </div>
                    </div>

                    <% if(currUser && listing.owner._id.equals(currUser.id)) { %>
                        <div class="d-flex flex-column gap-3">
                            <a href="/listings/<%= listing._id%>/edit"
                                class="btn btn-outline-custom text-center text-decoration-none">Edit Listing</a>
                            <form method="POST" action="/listings/<%=listing._id %>?_method=DELETE" class="m-0 w-100">
                                <button class="btn btn-primary-custom">Delete Listing</button>
                            </form>
                        </div>
                        <% } else { %>
                            <form action="/listings/<%= listing._id %>/bookings" method="POST" class="booking-form">
                                <div class="row g-2 mb-3">
                                    <div class="col-6">
                                        <label class="form-label small fw-bold text-muted mb-1"
                                            style="font-size: 0.8rem;">CHECK-IN</label>
                                        <input type="date" name="checkIn" id="checkInDate" class="form-control" required
                                            style="border-radius: 0.5rem; border: 1px solid #ccc; padding: 0.6rem;">
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label small fw-bold text-muted mb-1"
                                            style="font-size: 0.8rem;">CHECK-OUT</label>
                                        <input type="date" name="checkOut" id="checkOutDate" class="form-control"
                                            required
                                            style="border-radius: 0.5rem; border: 1px solid #ccc; padding: 0.6rem;">
                                    </div>
                                </div>
                                <div class="d-flex justify-content-between mb-3 fw-bold d-none p-3"
                                    id="priceCalculationContainer"
                                    style="background: rgba(0,0,0,0.03); border-radius: 0.5rem;">
                                    <span class="text-muted">₹<span id="basePrice">
                                            <%= listing.price %>
                                        </span> × <span id="numberOfNights">0</span> nights</span>
                                    <span>₹<span id="totalPriceDisplay">0</span></span>
                                </div>
                                <button type="submit" class="btn btn-primary-custom mb-3"
                                    id="reserveBtn">Reserve</button>
                            </form>
                            <p class="text-center text-muted small m-0">You won't be charged yet</p>

                            <script>
                                document.addEventListener('DOMContentLoaded', () => {
                                    const checkInInput = document.getElementById('checkInDate');
                                    const checkOutInput = document.getElementById('checkOutDate');
                                    const priceContainer = document.getElementById('priceCalculationContainer');
                                    const nightsDisplay = document.getElementById('numberOfNights');
                                    const totalDisplay = document.getElementById('totalPriceDisplay');
                                    const basePrice = parseInt(document.getElementById('basePrice').innerText.replace(/,/g, ''));

                                    function calculatePrice() {
                                        if (checkInInput.value && checkOutInput.value) {
                                            const start = new Date(checkInInput.value);
                                            const end = new Date(checkOutInput.value);

                                            if (end > start) {
                                                const diffTime = Math.abs(end - start);
                                                const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));

                                                priceContainer.classList.remove('d-none');
                                                nightsDisplay.innerText = diffDays;
                                                totalDisplay.innerText = (diffDays * basePrice).toLocaleString("en-IN");
                                            } else {
                                                priceContainer.classList.add('d-none');
                                            }
                                        }
                                    }

                                    checkInInput.addEventListener('change', () => {
                                        checkOutInput.setAttribute('min', checkInInput.value);
                                        calculatePrice();
                                    });
                                    checkOutInput.addEventListener('change', calculatePrice);

                                    // Set minimum dates
                                    const today = new Date().toISOString().split('T')[0];
                                    checkInInput.setAttribute('min', today);
                                    checkOutInput.setAttribute('min', today);
                                });
                            </script>
                            <% } %>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
