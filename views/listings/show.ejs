    <div id="listing-coordinates" data-coords='<%- JSON.stringify(listing && listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates : [0, 0]) %>' style="display: none;"></div>
    <script>
        (function() {
            const coords = JSON.parse(document.getElementById('listing-coordinates').dataset.coords);
            
            // Fetch Weather
            async function fetchWeather() {
                try {
                    const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${coords[1]}&longitude=${coords[0]}&current_weather=true`);
                    const data = await response.json();
                    const weather = data.current_weather;
                    const weatherContainer = document.getElementById('weather-content');
                    const weatherCard = weatherContainer.closest('.card');
                    
                    if(!weather) throw new Error("No weather data");

                    // Set dynamic background
                    const gradient = getWeatherGradient(weather.weathercode);
                    weatherCard.style.background = gradient;

                    weatherContainer.innerHTML = `
                        <div class="display-4 fw-bold mb-0">${Math.round(weather.temperature)}°C</div>
                        <div class="fs-5 opacity-90">${getWeatherDescription(weather.weathercode)}</div>
                        <div class="mt-2 small opacity-80">Wind Speed: ${weather.windspeed} km/h</div>
                    `;
                } catch (err) {
                    console.error("Weather Error:", err);
                    document.getElementById('weather-content').innerHTML = "<div class='py-3'>Weather info unavailable</div>";
                }
            }

            function getWeatherGradient(code) {
                const gradients = {
                    0: "linear-gradient(135deg, #FF8C00 0%, #FFD700 100%)", // Clear - Sunny
                    1: "linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)", // Mainly Clear
                    2: "linear-gradient(135deg, #4facfe 0%, #00f2fe 100%)", // Partly Cloudy
                    3: "linear-gradient(135deg, #bdc3c7 0%, #2c3e50 100%)", // Overcast
                    45: "linear-gradient(135deg, #757f9a 0%, #d7dde8 100%)", // Fog
                    61: "linear-gradient(135deg, #203a43 0%, #2c5364 100%)", // Rain
                    95: "linear-gradient(135deg, #0f0c29 0%, #302b63 100%, #24243e 100%)" // Storm
                };
                
                if (code >= 51 && code <= 67) return gradients[61]; // Any Rain
                if (code >= 71 && code <= 86) return "linear-gradient(135deg, #e6e9f0 0%, #eef1f5 100%)"; // Snow
                
                return gradients[code] || gradients[1];
            }

            function getWeatherDescription(code) {
                const codes = {
                    0: "Clear Sky", 1: "Mainly Clear", 2: "Partly Cloudy", 3: "Overcast",
                    45: "Fog", 48: "Depositing Rime Fog",
                    51: "Light Drizzle", 53: "Moderate Drizzle", 55: "Dense Drizzle",
                    61: "Light Rain", 63: "Moderate Rain", 65: "Heavy Rain",
                    71: "Light Snow", 73: "Moderate Snow", 75: "Heavy Snow",
                    95: "Thunderstorm"
                };
                return codes[code] || "Clear";
            }

            // Fetch Nearby POIs using Tilequery API
            async function fetchNearby() {
                try {
                    const token = "<%= process.env.MAP_TOKEN %>";
                    // Tilequery API searches for features within a radius (3000m) around the point
                    const response = await fetch(`https://api.mapbox.com/v4/mapbox.mapbox-streets-v8/tilequery/${coords[0]},${coords[1]}.json?radius=3000&layers=poi_label&access_token=${token}&limit=10`);
                    const data = await response.json();
                    
                    console.log(`Tilequery results for ${coords}:`, data.features.length);
                    
                    const list = document.getElementById('nearby-list');
                    list.innerHTML = "";
                    
                    if (!data.features || data.features.length === 0) {
                        // Fallback: Try a slightly larger radius or simple geocoding if tilequery fails
                        list.innerHTML = "<p class='text-muted text-center py-3'>No hotspots found nearby</p>";
                        return;
                    }

                    // Mapbox Tilequery returns features in order of proximity
                    const hotspots = data.features.slice(0, 4);

                    hotspots.forEach(poi => {
                        const props = poi.properties;
                        const category = props.type || props.class || 'Place';
                        let icon = 'fa-location-dot';
                        
                        // Smart icon selection based on Mapbox categories
                        if(category.includes('Park') || category.includes('Garden')) icon = 'fa-tree';
                        else if(category.includes('Food') || category.includes('Restaurant')) icon = 'fa-utensils';
                        else if(category.includes('Cafe') || category.includes('Coffee')) icon = 'fa-mug-hot';
                        else if(category.includes('Museum') || category.includes('Art')) icon = 'fa-landmark';
                        else if(category.includes('Shop') || category.includes('Mall')) icon = 'fa-bag-shopping';
                        else if(category.includes('Bar') || category.includes('Pub')) icon = 'fa-glass-cheers';

                        list.innerHTML += `
                            <div class="d-flex align-items-center p-2 rounded mb-1" style="background: rgba(227, 73, 73, 0.05);">
                                <div class="me-3 bg-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 40px; height: 40px; color: #e34949; box-shadow: 0 2px 5px rgba(0,0,0,0.05);">
                                    <i class="fa-solid ${icon}"></i>
                                </div>
                                <div style="min-width: 0;">
                                    <div class="fw-bold small text-truncate">${props.name}</div>
                                    <div class="text-muted text-truncate" style="font-size: 0.75rem;">${category}</div>
                                </div>
                            </div>
                        `;
                    });
                } catch (err) {
                    console.error("Nearby Error:", err);
                    document.getElementById('nearby-list').innerHTML = "<div class='py-3 text-muted'>Could not load hotspots</div>";
                }
            }

            fetchWeather();
            fetchNearby();
        })();
    </script>