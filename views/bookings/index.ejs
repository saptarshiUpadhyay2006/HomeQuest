<% layout("/layouts/boilerplate") -%>
<style>
    .booking-card {
        border-radius: 1.2rem;
        overflow: hidden;
        border: 1px solid rgba(0,0,0,0.08);
        box-shadow: 0 4px 15px rgba(0,0,0,0.04);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .booking-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
    }
    .booking-img {
        width: 100%;
        height: 200px;
        object-fit: cover;
    }
    .status-badge {
        color: white;
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-size: 0.85rem;
        font-weight: bold;
    }
    .status-badge.paid { background-color: #2ecc71; }
    .status-badge.pending { background-color: #f39c12; }
    .status-badge.failed { background-color: #e74c3c; }
    .status-badge.cancelled { background-color: #95a5a6; }
    .detail-icon {
        color: #777;
        width: 20px;
        text-align: center;
    }
</style>

<div class="container mt-5 mb-5">
    <h2 class="mb-4 fw-bold" style="font-family: 'Plus Jakarta Sans', sans-serif;">My Bookings</h2>

    <% if (bookings && bookings.length > 0) { %>
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            <% for(let booking of bookings) { %>
                <div class="col">
                    <div class="card booking-card h-100">
                        <% if (booking.listing) { %>
                            <img src="<%= (booking.listing.images && booking.listing.images.length > 0) ? booking.listing.images[0].url : '/images/placeholder.jpg' %>" class="booking-img" alt="<%= booking.listing.title %>">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title fw-bold mb-0 text-truncate" style="max-width: 70%;"><%= booking.listing.title %></h5>
                                    <% 
                                        let status = booking.paymentStatus || 'pending';
                                    %>
                                    <span class="status-badge <%= status %>">
                                        <%= status.charAt(0).toUpperCase() + status.slice(1) %>
                                    </span>
                                </div>
                                <p class="text-muted small mb-3"><i class="fa-solid fa-location-dot detail-icon me-1"></i> <%= booking.listing.location %>, <%= booking.listing.country %></p>
                                
                                <hr class="my-3">
                                
                                <div class="d-flex align-items-center mb-2">
                                    <i class="fa-regular fa-calendar-check detail-icon me-2"></i>
                                    <div>
                                        <p class="mb-0 small fw-bold">Check-in</p>
                                        <p class="mb-0 text-muted small"><%= booking.checkIn.toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %></p>
                                    </div>
                                </div>
                                
                                <div class="d-flex align-items-center mb-3">
                                    <i class="fa-regular fa-calendar-xmark detail-icon me-2"></i>
                                    <div>
                                        <p class="mb-0 small fw-bold">Check-out</p>
                                        <p class="mb-0 text-muted small"><%= booking.checkOut.toLocaleDateString('en-US', { weekday: 'short', year: 'numeric', month: 'short', day: 'numeric' }) %></p>
                                    </div>
                                </div>
                                
                                <div class="mt-auto pt-3 border-top">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span class="fw-bold">Total Paid</span>
                                        <span class="fs-5 fw-bold" style="color: #222;">₹<%= booking.totalPrice.toLocaleString("en-IN") %></span>
                                    </div>
                                </div>
                            </div>
                            <a href="/bookings/<%= booking._id %>" class="stretched-link"></a>
                        <% } else { %>
                            <div class="card-body d-flex flex-column justify-content-center align-items-center text-center p-4">
                                <i class="fa-solid fa-house-circle-xmark text-muted mb-3" style="font-size: 3rem;"></i>
                                <h5 class="fw-bold text-muted">Listing Unavailable</h5>
                                <p class="small text-muted mb-0">This listing has been deleted by the host.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>
    <% } else { %>
        <div class="text-center py-5">
            <i class="fa-solid fa-suitcase-rolling text-muted mb-3" style="font-size: 4rem;"></i>
            <h4 class="fw-bold text-muted">No bookings yet</h4>
            <p class="text-muted mb-4">Time to dust off your bags and start planning your next adventure.</p>
            <a href="/listings" class="btn btn-outline-dark px-4 py-2" style="border-radius: 30px; font-weight: 600;">Start Exploring</a>
        </div>
    <% } %>
</div>
