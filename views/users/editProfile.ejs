<% layout("/layouts/boilerplate") -%>
<div class="row mt-5">
    <div class="col-12 col-md-8 col-lg-6 offset-md-2 offset-lg-3">
        <div class="card shadow-lg border-0 p-4" style="border-radius: 2rem; background: var(--card-bg);">
            <h2 class="text-center mb-4 fw-800" style="color: #e34949;">Edit Profile</h2>
            <form action="/profile?_method=PUT" method="POST" enctype="multipart/form-data" novalidate class="needs-validation">
                
                <div class="text-center mb-4">
                    <% if(user.avatar && user.avatar.url) { %>
                        <img src="<%= user.avatar.url %>" alt="avatar" class="rounded-circle shadow-sm" style="width: 120px; height: 120px; object-fit: cover; border: 4px solid #e34949;">
                    <% } else { %>
                        <div class="profile-avatar mx-auto" style="width: 120px; height: 120px; font-size: 4rem;">
                            <i class="fa-solid fa-user"></i>
                        </div>
                    <% } %>
                </div>

                <div class="mb-4">
                    <label for="avatar" class="form-label fw-600">Change Profile Picture</label>
                    <input type="file" name="avatar" id="avatar" class="form-control" style="border-radius: 1rem;">
                </div>

                <div class="mb-4">
                    <label for="bio" class="form-label fw-600">Your Bio</label>
                    <textarea name="bio" id="bio" class="form-control" rows="5" placeholder="Tell us something about yourself..." style="border-radius: 1rem; line-height: 1.6;"><%= user.bio %></textarea>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary-custom py-3">Save Changes</button>
                    <a href="/profile" class="btn btn-link mt-2 text-decoration-none text-muted">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
