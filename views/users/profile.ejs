<% layout("/layouts/boilerplate") -%>
<style>
    .profile-header {
        background: linear-gradient(135deg, #e34949 0%, #ff7676 100%);
        color: white;
        padding: 4rem 2rem;
        border-radius: 2rem;
        margin-bottom: 3rem;
        box-shadow: 0 10px 30px rgba(227, 73, 73, 0.2);
    }
    @media (max-width: 768px) {
        .profile-header {
            padding: 2.5rem 1rem;
            border-radius: 1.5rem;
            margin-bottom: 2rem;
        }
    }
    .profile-avatar {
        width: 100px;
        height: 100px;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3rem;
        color: #e34949;
        margin-bottom: 1.5rem;
        box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }
    .nav-pills .nav-link {
        color: var(--text-color);
        font-weight: 600;
        padding: 0.8rem 1.5rem;
        border-radius: 12px;
        margin-right: 0.5rem;
        transition: all 0.3s ease;
    }
    .nav-pills .nav-link.active {
        background-color: #e34949;
        color: white;
    }
    .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 2rem;
    }
    .stat-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 1.5rem;
        padding: 2rem;
        text-align: center;
        transition: all 0.3s ease;
    }
    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2);
    }
    @media (max-width: 576px) {
        .stat-card {
            padding: 1.5rem;
        }
        .stat-number {
            font-size: 2rem;
        }
    }
    .stat-number {
        font-size: 2.5rem;
        font-weight: 800;
        color: #e34949;
    }
</style>

<div class="container py-5">
    <!-- Header Section -->
    <div class="profile-header text-center">
        <div class="d-flex flex-column align-items-center">
            <% if(user.avatar && user.avatar.url) { %>
                <img src="<%= user.avatar.url %>" alt="avatar" class="rounded-circle shadow-lg mb-3" style="width: 120px; height: 120px; object-fit: cover; border: 4px solid white;">
            <% } else { %>
                <div class="profile-avatar">
                    <i class="fa-solid fa-user"></i>
                </div>
            <% } %>
            <h1 class="fw-800 mb-1">Hi, <%= user.username %>!</h1>
            <p class="opacity-75 mb-3"><%= user.email %></p>
            
            <% if(user.bio) { %>
                <p class="mb-4 mx-auto" style="max-width: 600px; font-weight: 500; font-size: 1.1rem; line-height: 1.6;">"<%= user.bio %>"</p>
            <% } %>

            <a href="/profile/edit" class="btn btn-light px-4 py-2" style="border-radius: 12px; font-weight: 700; color: #e34949;">
                <i class="fa-solid fa-pen-to-square me-2"></i> Edit Profile
            </a>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-number"><%= listings.length %></div>
                <div class="text-muted fw-600">Properties Hosted</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-number"><%= bookings.length %></div>
                <div class="text-muted fw-600">Reservations Made</div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="stat-card">
                <div class="stat-number"><%= user.wishlist.length %></div>
                <div class="text-muted fw-600">Items in Wishlist</div>
            </div>
        </div>
    </div>

    <!-- Tabs Navigation -->
    <ul class="nav nav-pills mb-5 justify-content-center" id="pills-tab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active" id="pills-wishlist-tab" data-bs-toggle="pill" data-bs-target="#pills-wishlist" type="button" role="tab">Wishlist</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pills-listings-tab" data-bs-toggle="pill" data-bs-target="#pills-listings" type="button" role="tab">My Listings</button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link" id="pills-bookings-tab" data-bs-toggle="pill" data-bs-target="#pills-bookings" type="button" role="tab">My Bookings</button>
        </li>
    </ul>

    <!-- Tabs Content -->
    <div class="tab-content" id="pills-tabContent">
        <!-- Wishlist -->
        <div class="tab-pane fade show active" id="pills-wishlist" role="tabpanel">
            <% if(user.wishlist.length > 0) { %>
                <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4">
                    <% for(let listing of user.wishlist) { %>
                        <% if (listing) { %>
                            <div class="col">
                                <a href="/listings/<%= listing._id %>" class="listing-link">
                                    <div class="card h-100 listing-card">
                                        <img src="<%= (listing.images && listing.images.length > 0) ? listing.images[0].url : '/images/placeholder.jpg' %>" class="card-img-top" alt="listing_image">
                                        <div class="card-body">
                                            <p class="card-text">
                                                <b><%= listing.title %></b> <br>
                                                <span class="text-muted"><%= listing.location %>, <%= listing.country %></span>
                                            </p>
                                        </div>
                                    </div>
                                </a>
                            </div>
                        <% } %>
                    <% } %>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <i class="fa-regular fa-heart text-muted mb-3" style="font-size: 3rem;"></i>
                    <h4 class="text-muted">Your wishlist is empty</h4>
                    <p class="text-muted">Browse some properties and heart them to see them here!</p>
                </div>
            <% } %>
        </div>

        <!-- My Listings -->
        <div class="tab-pane fade" id="pills-listings" role="tabpanel">
            <% if(listings.length > 0) { %>
                <div class="row row-cols-lg-3 row-cols-md-2 row-cols-1 g-4">
                    <% for(let listing of listings) { %>
                        <div class="col">
                            <a href="/listings/<%= listing._id %>" class="listing-link">
                                <div class="card h-100 listing-card">
                                    <img src="<%= (listing.images && listing.images.length > 0) ? listing.images[0].url : '/images/placeholder.jpg' %>" class="card-img-top" alt="listing_image">
                                    <div class="card-body">
                                        <p class="card-text">
                                            <b><%= listing.title %></b> <br>
                                            <span class="text-muted"><%= listing.location %>, <%= listing.country %></span>
                                        </p>
                                        <div class="mt-3">
                                            <a href="/listings/<%= listing._id %>/edit" class="btn btn-sm btn-outline-dark">Edit</a>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    <% } %>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <i class="fa-solid fa-house-chimney-user text-muted mb-3" style="font-size: 3rem;"></i>
                    <h4 class="text-muted">You are not hosting any homes</h4>
                    <a href="/listings/new" class="btn btn-primary-custom mt-3">Start Hosting</a>
                </div>
            <% } %>
        </div>

        <!-- My Bookings -->
        <div class="tab-pane fade" id="pills-bookings" role="tabpanel">
            <% if(bookings.length > 0) { %>
                <div class="row row-cols-1 g-4">
                    <% for(let booking of bookings) { %>
                        <div class="col">
                            <div class="card listing-card shadow-sm border p-3">
                                <div class="row align-items-center">
                                    <% if (booking.listing) { %>
                                        <div class="col-md-2">
                                            <img src="<%= (booking.listing.images && booking.listing.images.length > 0) ? booking.listing.images[0].url : '/images/placeholder.jpg' %>" class="rounded" style="width: 100%; height: 100px; object-fit: cover;">
                                        </div>
                                        <div class="col-md-6">
                                            <h5 class="fw-bold mb-1"><%= booking.listing.title %></h5>
                                            <p class="text-muted mb-0"><%= booking.checkIn.toDateString() %> - <%= booking.checkOut.toDateString() %></p>
                                        </div>
                                        <div class="col-md-4 text-md-end">
                                            <div class="fw-800 text-danger fs-4">₹<%= booking.totalPrice.toLocaleString("en-IN") %></div>
                                            <a href="/listings/<%= booking.listing._id %>" class="btn btn-sm btn-outline-custom mt-2">View Property</a>
                                        </div>
                                    <% } else { %>
                                        <div class="col-md-8">
                                            <h5 class="fw-bold mb-1 text-muted">Property no longer available</h5>
                                            <p class="text-muted mb-0"><%= booking.checkIn.toDateString() %> - <%= booking.checkOut.toDateString() %></p>
                                        </div>
                                        <div class="col-md-4 text-md-end">
                                            <div class="fw-800 text-muted fs-4">₹<%= booking.totalPrice.toLocaleString("en-IN") %></div>
                                            <span class="badge bg-secondary">Archived</span>
                                        </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% } %>
                </div>
            <% } else { %>
                <div class="text-center py-5">
                    <i class="fa-solid fa-suitcase-rolling text-muted mb-3" style="font-size: 3rem;"></i>
                    <h4 class="text-muted">No upcoming trips</h4>
                    <a href="/listings" class="btn btn-primary-custom mt-3">Plan a Trip</a>
                </div>
            <% } %>
        </div>
    </div>
</div>
