<style>
  .custom-navbar {
    background: var(--navbar-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    transition: all 0.3s ease;
    padding: 0.8rem 0;
  }
  .navbar-brand i {
    font-size: 2.2rem;
    color: #e34949;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }
  .navbar-brand:hover i {
    transform: rotate(20deg) scale(1.15);
  }
  .brand-text {
    font-weight: 700;
    font-size: 1.4rem;
    color: #e34949;
    margin-left: 0.5rem;
    letter-spacing: -0.5px;
  }
  .nav-link {
    font-weight: 500;
    color: var(--text-color) !important;
    position: relative;
    padding: 0.5rem 1rem !important;
    transition: color 0.3s ease;
    margin: 0 0.2rem;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    width: 0;
    height: 2.5px;
    bottom: 2px;
    left: 50%;
    background-color: #e34949;
    transition: all 0.3s ease;
    transform: translateX(-50%);
    border-radius: 2px;
  }
  .nav-link:hover {
    color: #e34949 !important;
  }
  .nav-link:hover::after {
    width: 70%;
  }
  
  .search-container {
    position: relative;
    width: 100%;
    max-width: 450px;
  }
  .search-inp {
    border-radius: 50px;
    padding: 0.6rem 1.5rem 0.6rem 2.8rem;
    font-size: 0.95rem;
    border: 1px solid #e0e0e0;
    background-color: #f8f9fa;
    transition: all 0.3s ease;
    width: 100%;
    box-shadow: inset 0 2px 4px rgba(0,0,0,0.02);
  }
  .search-inp:focus {
    background-color: #fff;
    border-color: #e34949;
    box-shadow: 0 0 0 0.25rem rgba(227, 73, 73, 0.15);
    outline: none;
  }
  .search-icon-left {
    position: absolute;
    left: 1.2rem;
    top: 50%;
    transform: translateY(-50%);
    color: #888;
    z-index: 4;
    transition: color 0.3s ease;
  }
  .search-inp:focus + .search-icon-left {
    color: #e34949;
  }
  .btn-search {
    background-color: #e34949;
    color: white;
    border-radius: 50px;
    padding: 0.55rem 1.5rem;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    box-shadow: 0 4px 10px rgba(227, 73, 73, 0.25);
    margin-left: 0.5rem;
  }
  .btn-search:hover {
    background-color: #d13636;
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 6px 15px rgba(227, 73, 73, 0.35);
  }
  
  /* User Menu Dropdown Styles */
  .user-menu-btn {
    background-color: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: 30px;
    padding: 0.3rem 0.5rem 0.3rem 0.8rem;
    transition: all 0.3s ease;
    cursor: pointer;
    box-shadow: 0 2px 5px rgba(0,0,0,0.05);
  }
  .user-menu-btn:hover {
    box-shadow: 0 4px 10px rgba(0,0,0,0.15);
  }
  .user-avatar i {
    font-size: 1.8rem;
    color: var(--text-muted);
    transition: color 0.3s ease;
  }
  .user-menu-btn:hover .user-avatar i {
    color: #555;
  }
  
  .custom-dropdown {
    background-color: var(--card-bg) !important;
    border-radius: 14px;
    border: 1px solid var(--border-color);
    padding: 0.5rem 0;
    min-width: 240px;
    animation: fadeInDropdown 0.2s ease-out;
    margin-top: 0.5rem !important;
    z-index: 1050;
  }
  
  @keyframes fadeInDropdown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  
  .custom-dropdown .dropdown-item {
    padding: 0.6rem 1.2rem;
    transition: background-color 0.2s ease;
    color: var(--text-color);
    font-size: 0.95rem;
  }
  .custom-dropdown .dropdown-item:hover {
    background-color: rgba(227, 73, 73, 0.1);
  }
  .custom-dropdown .dropdown-item.fw-bold {
    color: var(--text-color);
  }
  
  @media (max-width: 768px) {
    .search-container {
      margin-top: 1rem;
      margin-bottom: 1rem;
      max-width: 100%;
    }
    .custom-navbar {
      padding: 0.5rem 0;
    }
    .navbar-collapse {
      background-color: var(--card-bg);
      padding: 1rem;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.1);
      margin-top: 0.5rem;
      position: absolute;
      top: 100%;
      left: 1rem;
      right: 1rem;
      z-index: 1040;
    }
    .user-menu-btn {
      margin-top: 0.5rem;
    }
    .custom-dropdown {
      width: 100%;
      text-align: center;
      border: none;
      box-shadow: none !important;
      padding: 0;
    }
  }

  /* Theme Switcher */
  .theme-switch-wrapper {
    display: flex;
    align-items: center;
    margin-right: 1.5rem;
  }
  .theme-switch {
    display: inline-block;
    height: 26px;
    position: relative;
    width: 50px;
  }
  .theme-switch input {
    display:none;
  }
  .slider {
    background-color: #ccc;
    bottom: 0;
    cursor: pointer;
    left: 0;
    position: absolute;
    right: 0;
    top: 0;
    transition: .4s;
    border-radius: 34px;
  }
  .slider:before {
    background-color: #fff;
    bottom: 4px;
    content: "";
    height: 18px;
    left: 4px;
    position: absolute;
    transition: .4s;
    width: 18px;
    border-radius: 50%;
  }
  input:checked + .slider {
    background-color: #e34949;
  }
  input:checked + .slider:before {
    transform: translateX(24px);
  }
  .theme-icon {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-right: 8px;
  }
</style>

<nav class="navbar navbar-expand-md custom-navbar sticky-top">
  <div class="container-fluid px-3 px-md-4">
    <a class="navbar-brand d-flex align-items-center" href="/listings">
      <i class="fa-regular fa-compass"></i>
      <span class="brand-text d-none d-sm-block">HomeQuest</span>
    </a>
    
    <button 
      class="navbar-toggler border-0 shadow-none" 
      type="button" 
      data-bs-toggle="collapse" 
      data-bs-target="#navbarSupportedContent"
      aria-controls="navbarSupportedContent" 
      aria-expanded="false" 
      aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarSupportedContent">
      <div class="navbar-nav me-auto mb-2 mb-lg-0 ms-md-4">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <form class="d-flex mx-auto search-container" role="search" method="GET" action="/listings">
        <% if (typeof activeCategory !== 'undefined' && activeCategory) { %>
            <input type="hidden" name="category" value="<%= activeCategory %>">
        <% } %>
        <% if (typeof minPrice !== 'undefined' && minPrice) { %>
            <input type="hidden" name="minPrice" value="<%= minPrice %>">
        <% } %>
        <% if (typeof maxPrice !== 'undefined' && maxPrice) { %>
            <input type="hidden" name="maxPrice" value="<%= maxPrice %>">
        <% } %>
        <div class="position-relative flex-grow-1">
          <input
            class="form-control search-inp"
            type="search"
            placeholder="Search destinations"
            name="q"
            value="<%= typeof searchQuery !== 'undefined' ? searchQuery : '' %>"
          />
          <i class="fa-solid fa-magnifying-glass search-icon-left"></i>
        </div>
        <button class="btn-search d-flex align-items-center justify-content-center" type="submit">
          Search
        </button>
      </form>

      <div class="navbar-nav ms-auto align-items-center mt-3 mt-md-0 flex-row justify-content-center">
        <div class="theme-switch-wrapper me-3">
          <i class="fa-solid fa-moon theme-icon"></i>
          <label class="theme-switch" for="checkbox">
            <input type="checkbox" id="checkbox" />
            <div class="slider round"></div>
          </label>
        </div>
        <a class="nav-link fw-bold me-3 d-none d-md-block" style="font-size: 0.95rem; color: var(--text-color) !important;" href="/listings/new">Add Your Home</a>
        
        <div class="dropdown">
          <button class="user-menu-btn d-flex align-items-center" type="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="fa-solid fa-bars" style="color: #555; margin-right: 2px;"></i>
            <div class="user-avatar ms-2 d-flex align-items-center">
              <i class="fa-solid fa-circle-user"></i>
            </div>
          </button>
          <ul class="dropdown-menu dropdown-menu-end custom-dropdown shadow-lg">
            <% if(!currUser) { %>
              <li><a class="dropdown-item fw-bold" href="/signup">Sign up</a></li>
              <li><a class="dropdown-item" href="/login">Log in</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item d-md-none" href="/listings/new">Add Your Home</a></li>
            <% } else { %>
              <li><span class="dropdown-item-text text-muted" style="font-size: 0.85rem;">Welcome back!</span></li>
              <li><a class="dropdown-item fw-bold" href="/profile">My Profile</a></li>
              <li><a class="dropdown-item fw-bold" href="/bookings">My Bookings</a></li>
              <li><a class="dropdown-item fw-bold" href="/listings/dashboard">Host Dashboard</a></li>
              <li><a class="dropdown-item fw-bold" href="/listings/new">Add Your Home</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger fw-bold" href="/logout">Log out</a></li>
            <% } %>
          </ul>
        </div>
      </div>
    </div>
  </div>
</nav>
